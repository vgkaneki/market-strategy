{
  "name": "@market-strategy/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "audit:contracts": "cd ../../contracts && npm run audit:prep",
    "smoke:prod": "node scripts/production-smoke-test.mjs",
    "lce:install": "cd ../.. && node scripts/install-lce-sdk.mjs",
    "lce:verify": "cd ../.. && node scripts/verify-lce-sdk.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "pino": "^9.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0",
    "@clickhouse/client": "^1.11.2",
    "decimal.js": "^10.4.3",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "@fastify/cookie": "^11.0.2",
    "nanoid": "^5.1.5",
    "playwright": "^1.55.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/jsonwebtoken": "^9.0.7"
  }
}
